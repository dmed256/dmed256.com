block global
  - var title          = '404: Oops'
  - var placingTabBody = 'blog'

extends ./page

mixin tabBody
  // 285px comes from the extra width to hide the scroll bar
  div(style="position: relative; width: calc(100% - 300px); background-color: #EAF5F9; padding: 26px 0 14px 0; text-align: center; position: absolute; top: calc(50% - 80px);")
    div(style="margin: 0px auto 0px auto; position: relative; display: inline-block; text-align: left;")
      div(style="margin: auto; width: 80px; text-align:center; color: #6992B5;")
        i.huge.spy.icon(style="margin-left:5px;")
      p(style="text-align: center; color: #6C6C6C; font-size: 18px; font-family: openSansBold; margin: 15px 0 10px 0;")
        | 404
      div(style="margin: 10px; color: #6C6C6C; font-family: ralewayRegular; font-weight: 900;")
        | You almost found the s..er se...t w...ite!
